---
title: Sarh — End-to-end system flow (with NFT licence on blockchain)
---
flowchart LR

    subgraph CIT[المواطن &middot; Citizen]
      C1[تسجيل / دخول]
      C2[تقديم عقار جديد<br/>+ مستندات + إحداثيات]
      C3[استلام السند الموقع<br/>+ شهادة VC + رخصة NFT]
    end

    subgraph OFF[موظف التسجيل / المراجع]
      O1[قائمة المراجعة]
      O2{قرار فني}
      O3[طلب توضيح]
      O4[رفض مع سبب]
      O5[توصية بالاعتماد]
    end

    subgraph MGR[مدير الإدارة &middot; Department Manager]
      M1[قائمة الاعتمادات النهائية]
      M2[اعتماد نهائي + رقم القرار]
      M3[رفض الاعتماد]
    end

    subgraph ISS[مصدر الهويات]
      I1[إصدار بطاقة NFC جديدة]
      I2[ربط NTAG 424 DNA<br/>+ كتابة المفاتيح]
      I3[إعادة إصدار / استبدال]
    end

    subgraph ADM[الإدارة / المدقق]
      A1[لوحة التحكم<br/>إحصائيات وتقارير]
      A2[سجل التدقيق<br/>append-only]
      A3[إدارة المستخدمين]
    end

    subgraph BACK[الخادم &middot; .NET 8 API + SignalR]
      API[/api/v1/*<br/>JWT HS256/]
      DB[(SQL Server 2019<br/>geography + audit triggers<br/>+ property_nfts + ownership_history)]
      FS[(Local filesystem<br/>storage_root)]
      SSI[ACA-Py<br/>Hyperledger Aries]
      IPFS[IPFS pinning]
    end

    subgraph CHAIN[سلسلة الكتل &middot; Blockchain]
      BC[Ethereum / Hyperledger]
      SC[Smart Contract<br/>ERC-721 / chaincode]
    end

    subgraph PUB[الجمهور &middot; Public]
      V1[التحقق من سند<br/>عبر QR أو رمز]
      V2[تحقق NFC<br/>SUN counter]
      V3[تحقق من رخصة NFT<br/>على السلسلة]
    end

    C1 --> API
    C2 --> API
    API --> DB
    API --> FS

    DB --> O1
    O1 --> O2
    O2 -->|needs_clarification| O3 --> C2
    O2 -->|reject| O4 --> C2
    O2 -->|recommend_approval| O5

    O5 --> API --> DB --> M1
    M1 --> M2
    M1 --> M3 --> C2

    M2 --> API
    API -->|"PDF + PAdES sign"| FS
    API -->|"VC issue"| SSI
    SSI --> DB
    API -->|"pin metadata.json"| IPFS
    IPFS --> API
    API -->|"mint(tokenId, ownerDID, tokenURI)"| BC
    BC --> SC
    SC -->|"Transfer event + tx hash"| BC
    BC --> API
    API --> DB
    DB --> C3

    C1 -. "first time" .-> I1
    I1 --> I2
    I2 --> DB
    I2 --> FS
    I3 --> I2

    DB --> A1
    DB --> A2
    DB --> A3

    V1 --> API
    V2 --> API
    V3 --> API
    API -->|"verify hash + signature"| DB
    API -->|"ownerOf(tokenId)"| BC
---
title: Sarh — Database schema (core tables)
---
erDiagram
    auth_users ||--o| officers : "auth_user_id"
    auth_users ||--o{ id_issuance_history : "issued by"
    citizens   ||--o{ properties : "owner_citizen_id"
    citizens   ||--o{ digital_id_cards : "citizen_id"
    citizens   ||--o{ id_issuance_history : "subject"
    officers   ||--o{ properties : "reviewed_by_officer_id"
    officers   ||--o{ digital_id_cards : "issued_by_officer_id"
    officers   ||--o{ id_issuance_history : "officer_id"
    regions    ||--o{ citizens : "region_id"
    regions    ||--o{ officers : "region_id"
    regions    ||--o{ properties : "region_id"
    properties ||--|| registration_requests : "submission"
    properties ||--o{ property_documents : "attachments"
    registration_requests ||--o{ review_comments : "discussion"
    digital_id_cards ||--|| nfc_card_secrets : "1:1 KMS keys"
    digital_id_cards ||--o| ssi_wallets : "SSI wallet"
    ssi_wallets ||--o{ ssi_credentials : "issued VCs"
    citizens   ||--o{ notifications : "recipient"
    auth_users ||--o{ audit_log : "actor"
    properties ||--o| property_nfts : "tokenised as"
    properties ||--o{ ownership_history : "transfer chain"
    property_nfts ||--o{ ownership_history : "transferred"
    officers   ||--o{ property_nfts : "minted by (manager)"

    auth_users {
        UNIQUEIDENTIFIER id PK
        NVARCHAR email
        NVARCHAR encrypted_password
        DATETIMEOFFSET email_confirmed_at
        DATETIMEOFFSET last_sign_in_at
        NVARCHAR raw_app_meta_data "JSON"
        DATETIMEOFFSET created_at
    }

    officers {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER auth_user_id FK
        NVARCHAR employee_no
        NVARCHAR full_name_ar
        NVARCHAR role "super_admin/registry_officer/reviewer/auditor/id_issuer/department_manager"
        INT region_id FK
        INT municipality_id
        NVARCHAR permissions "JSON"
        BIT is_active
    }

    citizens {
        UNIQUEIDENTIFIER id PK
        NVARCHAR first_name_ar
        NVARCHAR father_name_ar
        NVARCHAR grandfather_name_ar
        NVARCHAR family_name_ar
        NVARCHAR legacy_national_no "for migration"
        NVARCHAR gender
        DATE birth_date
        INT region_id FK
        BIT is_active
    }

    properties {
        UNIQUEIDENTIFIER id PK
        NVARCHAR property_code
        UNIQUEIDENTIFIER owner_citizen_id FK
        NVARCHAR property_type
        INT region_id FK
        GEOGRAPHY boundary_polygon
        GEOGRAPHY centroid "auto from trigger"
        DECIMAL area_sqm
        NVARCHAR status "draft/pending/under_review/approved/rejected"
        UNIQUEIDENTIFIER reviewed_by_officer_id FK
        NVARCHAR deed_pdf_path
        NVARCHAR deed_signed_hash "PAdES SHA256"
        NVARCHAR vc_credential_id "SSI VC"
    }

    registration_requests {
        UNIQUEIDENTIFIER id PK
        NVARCHAR request_no
        UNIQUEIDENTIFIER property_id FK
        NVARCHAR current_status
        DATETIMEOFFSET submitted_at
    }

    review_comments {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER request_id FK
        UNIQUEIDENTIFIER officer_id FK
        NVARCHAR body_ar
        DATETIMEOFFSET created_at
    }

    property_documents {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER property_id FK
        NVARCHAR doc_type
        NVARCHAR storage_path
        NVARCHAR sha256
    }

    digital_id_cards {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER citizen_id FK
        NVARCHAR digital_id_number
        NVARCHAR card_serial
        NVARCHAR nfc_uid
        BIGINT last_nfc_counter "rolling"
        NVARCHAR did "did:sov:..."
        UNIQUEIDENTIFIER issued_by_officer_id FK
        DATETIMEOFFSET issued_at
        DATETIMEOFFSET expires_at
        NVARCHAR status "active/revoked/expired"
    }

    nfc_card_secrets {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER card_id FK
        VARBINARY meta_read_key_enc "AES-GCM wrapped"
        VARBINARY sdm_file_read_key_enc
        NVARCHAR kms_key_id
    }

    id_issuance_history {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER citizen_id FK
        UNIQUEIDENTIFIER card_id FK
        NVARCHAR action "issue/reissue/revoke"
        UNIQUEIDENTIFIER officer_id FK
    }

    ssi_wallets {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER citizen_id FK
        NVARCHAR did
        NVARCHAR did_doc "JSON"
    }

    ssi_credentials {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER wallet_id FK
        NVARCHAR credential_type "PropertyDeed/CitizenIdentity"
        NVARCHAR subject_id
        NVARCHAR cred_data "JSON"
    }

    notifications {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER recipient_citizen_id FK
        NVARCHAR title_ar
        NVARCHAR body_ar
        NVARCHAR channel "in_app/sms/email"
        BIT read
    }

    audit_log {
        BIGINT id PK "IDENTITY"
        UNIQUEIDENTIFIER actor_user_id FK
        NVARCHAR action
        NVARCHAR entity
        UNIQUEIDENTIFIER entity_id
        NVARCHAR before_state "JSON"
        NVARCHAR after_state "JSON"
        DATETIMEOFFSET occurred_at
    }

    regions {
        INT id PK
        NVARCHAR code
        NVARCHAR name_ar
        NVARCHAR name_en
    }

    property_nfts {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER property_id FK
        NVARCHAR token_id "uint256 as string"
        NVARCHAR contract_address "0x… EVM addr"
        NVARCHAR network "ethereum-sepolia / hyperledger-fabric"
        NVARCHAR standard "ERC-721 / chaincode"
        NVARCHAR owner_did "did:sov:…"
        NVARCHAR metadata_uri "ipfs://… or https://"
        NVARCHAR metadata_sha256
        NVARCHAR mint_tx_hash
        BIGINT mint_block_number
        UNIQUEIDENTIFIER minted_by_officer_id FK "department_manager"
        DATETIMEOFFSET minted_at
        NVARCHAR status "pending/minted/transferred/burned"
    }

    ownership_history {
        UNIQUEIDENTIFIER id PK
        UNIQUEIDENTIFIER property_id FK
        UNIQUEIDENTIFIER nft_id FK
        NVARCHAR from_did "null on first mint"
        NVARCHAR to_did
        UNIQUEIDENTIFIER from_citizen_id FK
        UNIQUEIDENTIFIER to_citizen_id FK
        NVARCHAR transfer_tx_hash
        NVARCHAR reason "initial_mint/sale/inheritance/court_order"
        DATETIMEOFFSET transferred_at
    }

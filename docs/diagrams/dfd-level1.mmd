---
title: Sarh — DFD Level 1 (main processes inside Sarh Platform)
---
flowchart LR

    Citizen[Citizen]
    Officer[Registry officer]
    Manager[Department manager]
    SSI[SSI Provider]
    MAP[Map Service API]
    NOTIF[Notification Service]
    NFT[NFT Minting Service]

    P1((1.0<br/>Account &<br/>Identity Mgmt))
    P2((2.0<br/>Land Claim<br/>Processing))
    P3((3.0<br/>Spatial &<br/>Technical Auditing))
    P4((4.0<br/>NFT Documentation<br/>& NFT Minting))
    P5((5.0<br/>Notifications))

    D1[(D1<br/>Users / DID file)]
    D2[(D2<br/>Claims & Properties store)]
    D3[(D3<br/>Blockchain Ledger file<br/>property_nfts + ownership_history)]
    D4[(D4<br/>Audit log)]

    Citizen -->|"Profile + identity info"| P1
    P1 -->|"Request identity verification"| SSI
    SSI -->|"Verification result"| P1
    P1 -->|"Store verified user profile"| D1

    Citizen -->|"Land documents + GPS coordinates"| P2
    P2 -->|"Store new request data"| D2
    P2 -->|"Claim data for auditing"| P3

    Officer -->|"Map verification + report"| P3
    P3 -->|"API coordinates"| MAP
    MAP -->|"Spatial validation result"| P3
    P3 -->|"Store audited report"| D2
    P3 -->|"Requests for review"| Officer

    P3 -->|"Approval requests"| P4
    Manager -->|"Approval response"| P4
    P4 -->|"Token id + minting confirmation"| NFT
    NFT -->|"Tx hash + token id"| P4
    P4 -->|"Store NFT record"| D3
    P4 -->|"Audit entry"| D4

    P4 -->|"Notification content + user contact"| P5
    P5 -->|"Push / SMS / Email"| NOTIF
    NOTIF -->|"Delivery status"| P5
    P5 -->|"Status update"| Citizen
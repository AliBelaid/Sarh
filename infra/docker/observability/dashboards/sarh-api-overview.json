{
  "uid": "sarh-api-overview",
  "title": "Sarh — API Overview",
  "tags": ["sarh", "api"],
  "timezone": "Africa/Tripoli",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count{service=\"api\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx rate (req/s)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count{service=\"api\",status_code=~\"5..\"}[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Status code mix",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status_code) (rate(http_request_duration_seconds_count{service=\"api\"}[5m]))", "legendFormat": "{{status_code}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "API errors (Loki)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "loki" },
      "targets": [
        { "expr": "{service=\"api\", level=\"error\"}", "refId": "A" }
      ]
    }
  ]
}

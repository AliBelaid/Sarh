# Sijilli — production environment template.
#
# Copy to `.env` next to docker-compose.production.yml and fill in real
# values. Never commit the populated `.env` — `.gitignore` excludes it.
#
# Generate strong secrets with:  openssl rand -hex 32

# ---- Image registry / version --------------------------------------------
SIJILLI_REGISTRY=ghcr.io/lvct
SIJILLI_VERSION=latest

# ---- Supabase (managed) --------------------------------------------------
# From the Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Direct connection string used by the API for Prisma + pg_dump backups.
# Must include `?sslmode=require`.
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres?sslmode=require

# ---- API ------------------------------------------------------------------
# Comma-separated origins permitted by the API CORS guard. Must include
# every public hostname.
CORS_ORIGINS=https://sijilli.ly,https://verify.sijilli.ly,https://officer.sijilli.ly,https://issuer.sijilli.ly,https://admin.sijilli.ly
LOG_LEVEL=info

# ---- PAdES deed signing ---------------------------------------------------
# PKCS#12 bundle holding the deed-signing cert + private key. Mounted as a
# Docker secret at the path below; populate the *_HOST var with the path on
# the host filesystem the secret should be sourced from.
DEED_SIGNING_CERT_PATH=/run/secrets/deed-signing.p12
DEED_SIGNING_CERT_PATH_HOST=./secrets/deed-signing.p12
DEED_SIGNING_CERT_PASSPHRASE=replace-with-p12-passphrase

# ---- NFC KMS (NTAG 424 DNA master keys) ----------------------------------
# AWS KMS key encrypting per-card SUN derivation keys. Read by apps/api at
# boot to decrypt the card-issuance keystore.
NFC_KMS_KEY_ID=arn:aws:kms:eu-south-1:000000000000:key/00000000-0000-0000-0000-000000000000
NFC_KMS_REGION=eu-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ---- ACA-Py / SSI ---------------------------------------------------------
# Public agent endpoint — must be reachable from holder wallets on the
# internet. Typically https://agent.sijilli.ly:8020 fronted by the edge.
ACA_PY_PUBLIC_ENDPOINT=https://agent.sijilli.ly
ACA_PY_ADMIN_URL=http://aca-py:8021
ACA_PY_ADMIN_API_KEY=replace-with-strong-admin-key
ACA_PY_WALLET_KEY=replace-with-strong-wallet-key
ACA_PY_MT_JWT_SECRET=replace-with-strong-mt-jwt-secret
# Sovrin MainNet for production. Use BuilderNet during pilot.
ACA_PY_GENESIS_URL=https://raw.githubusercontent.com/sovrin-foundation/sovrin/master/sovrin/pool_transactions_live_genesis
ACA_PY_TAILS_URL=https://tails.sijilli.ly

# ---- Backup ---------------------------------------------------------------
# `age` recipient list (comma-separated). Each operator with restore
# privileges should own a recipient. Public keys are safe to commit; the
# matching private keys are NOT.
BACKUP_AGE_RECIPIENTS=age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,age1yyyyyy
BACKUP_S3_BUCKET=sijilli-backups
BACKUP_S3_PREFIX=supabase
# Optional: separate IAM credentials for the backup uploader. Falls back
# to the API's AWS_* if left blank.
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=

# ---- Grafana --------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
GRAFANA_ROOT_URL=https://grafana.sijilli.ly

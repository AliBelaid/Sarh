{
  "name": "sarh",
  "version": "0.1.0",
  "private": true,
  "description": "Sarh — Libyan Real Estate Registry + Digital Identity (LVCT)",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:api": "dotnet run --project apps/api-dotnet/Sarh.Api.csproj",
    "dev:web": "pnpm --filter @sarh/web start",
    "db:reset": "pwsh ./scripts/db/run-migrations.ps1 -Server localhost -Reset",
    "diagrams:render": "node docs/diagrams/render.mjs && node docs/diagrams/render-a4.mjs",
    "diagrams:classic": "node docs/diagrams/render-classic-local.mjs",
    "diagrams:pdf": "node docs/print-diagrams-pdf.mjs",
    "diagrams:pdf:classic": "node docs/print-classic-pdf.mjs"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}

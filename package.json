{
  "name": "sarh",
  "version": "0.1.0",
  "private": true,
  "description": "Sarh — Libyan Real Estate Registry + Digital Identity (LVCT)",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:api": "dotnet run --project apps/api-dotnet/Sarh.Api.csproj",
    "dev:web": "pnpm --filter @sarh/web start",
    "_legacy:dev:web-citizen": "pnpm --filter @sarh/web-citizen start",
    "_legacy:dev:web-officer": "pnpm --filter @sarh/web-officer start",
    "_legacy:dev:web-id-issuer": "pnpm --filter @sarh/web-id-issuer start",
    "_legacy:dev:web-admin": "pnpm --filter @sarh/web-admin start"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}
